# Argos udev rules for the Raspberry Pi.
# Replace these with serial-number-specific rules once the final hardware is on hand.
#
# Install on the Pi:
#   sudo cp 99-argos-devices.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# Check devices:
#   udevadm info -a -n /dev/ttyUSB0
#   udevadm info -a -n /dev/ttyACM0

# RPLiDAR A1M8 via CP2102 USB-UART bridge
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", SYMLINK+="ttyLIDAR", GROUP="dialout", MODE="0660"

# ESP32-C6 running micro-ROS over native USB CDC.
#
# 303a:1001 is Espressif's standard JTAG/CDC composite (covers most C-series
# boards via the built-in USB Serial/JTAG controller). Verify on the actual
# board with `lsusb` before relying on this — third-party boards sometimes
# wire a CP210x or CH340 instead, in which case the IDs match the LiDAR rule
# above and you'll need a SERIAL match to disambiguate.
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", SYMLINK+="ttyESP32", GROUP="dialout", MODE="0660"
