<?xml version="1.0"?>
<robot name="quadruped" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="base_length" value="0.26"/>
  <xacro:property name="base_width" value="0.16"/>
  <xacro:property name="base_height" value="0.06"/>
  <xacro:property name="coxa_length" value="0.05162"/>
  <xacro:property name="femur_length" value="0.130"/>
  <xacro:property name="tibia_length" value="0.150"/>
  <xacro:property name="link_radius" value="0.012"/>
  <xacro:property name="foot_radius" value="0.018"/>
  <xacro:property name="leg_mass" value="0.10"/>

  <material name="body_gray">
    <color rgba="0.28 0.31 0.36 1.0"/>
  </material>
  <material name="leg_orange">
    <color rgba="0.86 0.42 0.12 1.0"/>
  </material>
  <material name="sensor_black">
    <color rgba="0.12 0.12 0.12 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="body_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.03" iyz="0.0" izz="0.04"/>
    </inertial>
  </link>

  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="leg" params="prefix mount_x mount_y side_sign">
    <link name="${prefix}_coxa_link">
      <visual>
        <origin xyz="0 ${side_sign * coxa_length / 2.0} 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.018 ${coxa_length} 0.018"/>
        </geometry>
        <material name="leg_orange"/>
      </visual>
      <collision>
        <origin xyz="0 ${side_sign * coxa_length / 2.0} 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.018 ${coxa_length} 0.018"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 ${side_sign * coxa_length / 2.0} 0" rpy="0 0 0"/>
        <mass value="${leg_mass}"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${prefix}_coxa_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${prefix}_coxa_link"/>
      <origin xyz="${mount_x} ${mount_y} 0.0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-1.5708" upper="1.5708" effort="50.0" velocity="6.0"/>
    </joint>

    <link name="${prefix}_femur_link">
      <visual>
        <origin xyz="0 0 ${-femur_length / 2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${femur_length}"/>
        </geometry>
        <material name="leg_orange"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-femur_length / 2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${femur_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-femur_length / 2.0}" rpy="0 0 0"/>
        <mass value="${leg_mass}"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${prefix}_femur_joint" type="revolute">
      <parent link="${prefix}_coxa_link"/>
      <child link="${prefix}_femur_link"/>
      <origin xyz="0 ${side_sign * coxa_length} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.0944" upper="2.0944" effort="50.0" velocity="6.0"/>
    </joint>

    <link name="${prefix}_tibia_link">
      <visual>
        <origin xyz="0 0 ${-tibia_length / 2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${tibia_length}"/>
        </geometry>
        <material name="leg_orange"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-tibia_length / 2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${link_radius}" length="${tibia_length}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-tibia_length / 2.0}" rpy="0 0 0"/>
        <mass value="${leg_mass}"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${prefix}_tibia_joint" type="revolute">
      <parent link="${prefix}_femur_link"/>
      <child link="${prefix}_tibia_link"/>
      <origin xyz="0 0 ${-femur_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.0944" upper="2.0944" effort="50.0" velocity="6.0"/>
    </joint>

    <link name="${prefix}_foot_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${foot_radius}"/>
        </geometry>
        <material name="sensor_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${foot_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.02"/>
        <inertia ixx="1e-05" ixy="0.0" ixz="0.0" iyy="1e-05" iyz="0.0" izz="1e-05"/>
      </inertial>
    </link>

    <joint name="${prefix}_foot_fixed_joint" type="fixed">
      <parent link="${prefix}_tibia_link"/>
      <child link="${prefix}_foot_link"/>
      <origin xyz="0 0 ${-tibia_length}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:leg prefix="FR" mount_x="0.11165" mount_y="-0.061" side_sign="-1"/>
  <xacro:leg prefix="FL" mount_x="0.11165" mount_y="0.061" side_sign="1"/>
  <xacro:leg prefix="RR" mount_x="-0.11165" mount_y="-0.061" side_sign="-1"/>
  <xacro:leg prefix="RL" mount_x="-0.11165" mount_y="0.061" side_sign="1"/>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.05"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
  </link>
  <joint name="lidar_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.11 0.0 0.055" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.09 0.025 0.025"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
  </link>
  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.10 0.0 0.035" rpy="0 0 0"/>
  </joint>

  <link name="thermal_link">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.02"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
  </link>
  <joint name="thermal_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="thermal_link"/>
    <origin xyz="0.085 0.045 0.04" rpy="0 0 0"/>
  </joint>

  <link name="gas_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.02"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
  </link>
  <joint name="gas_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gas_link"/>
    <origin xyz="0.0 0.0 -0.015" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
  </link>
  <joint name="imu_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.02" rpy="0 0 0"/>
  </joint>

</robot>
